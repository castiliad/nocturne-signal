---
const nodes = [
  {
    id: 'claim',
    number: '01',
    title: 'Claim',
    subtitle: 'Static GitHub Pages delivery',
    body: 'A visible promise is made in public copy: this is a static surface, not a live private dashboard.'
  },
  {
    id: 'contract',
    number: '02',
    title: 'Contract',
    subtitle: 'Allowed and forbidden claims',
    body: 'Site and brand contracts define what future agents can say, change, or escalate for approval.'
  },
  {
    id: 'qa',
    number: '03',
    title: 'QA',
    subtitle: 'Repo-local verification gates',
    body: 'Checks validate contracts, claims, links, generated data, layout, build output, and browser behavior.'
  },
  {
    id: 'deploy',
    number: '04',
    title: 'Deploy',
    subtitle: 'GitHub Pages publication',
    body: 'A Pages workflow builds the static site and records deploy evidence future maintainers can inspect.'
  },
  {
    id: 'live',
    number: '05',
    title: 'Live',
    subtitle: 'Post-deploy content check',
    body: 'The verifier fetches the live URL and confirms stable expected text after publication.'
  }
];
---
<section class="proof-chain" aria-labelledby="proof-chain-title">
  <div class="proof-chain-copy">
    <div class="section-kicker">Proof-chain diagram</div>
    <h2 id="proof-chain-title">Claim → Contract → QA → Deploy → Live</h2>
    <p>Every strong line should travel through the same static operating envelope before it earns space on the page.</p>
  </div>

  <div class="proof-chain-canvas" aria-label="Diagram showing claim to contract to QA to deploy to live verification">
    <svg viewBox="0 0 1120 360" role="img" aria-labelledby="proof-chain-svg-title proof-chain-svg-desc">
      <title id="proof-chain-svg-title">Proof-chain diagram</title>
      <desc id="proof-chain-svg-desc">A five-step flow connects Claim, Contract, QA, Deploy, and Live verification with static-safety checkpoints.</desc>
      <defs>
        <linearGradient id="proofNodeGlow" x1="0" x2="1" y1="0" y2="1">
          <stop offset="0%" stop-color="#00d992" stop-opacity="0.32" />
          <stop offset="58%" stop-color="#7170ff" stop-opacity="0.12" />
          <stop offset="100%" stop-color="#ffffff" stop-opacity="0.04" />
        </linearGradient>
        <marker id="proofArrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
          <path d="M 0 0 L 10 5 L 0 10 z" fill="#00d992" opacity="0.85" />
        </marker>
        <filter id="softGlow" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="5" result="blur" />
          <feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
        </filter>
      </defs>

      <rect x="12" y="18" width="1096" height="324" rx="24" fill="rgba(5,5,7,0.64)" stroke="rgba(242,242,242,0.12)" />
      <path d="M 64 180 C 190 92, 288 92, 414 180 S 654 268, 780 180 S 976 92, 1056 180" fill="none" stroke="rgba(0,217,146,0.14)" stroke-width="54" stroke-linecap="round" />
      <path d="M 132 180 L 306 180 L 480 180 L 654 180 L 828 180 L 990 180" fill="none" stroke="rgba(0,217,146,0.55)" stroke-width="2.5" stroke-dasharray="8 10" marker-end="url(#proofArrow)" />

      <g class="proof-svg-node" transform="translate(56 74)">
        <rect width="170" height="212" rx="16" fill="#0f172a" />
        <rect width="170" height="212" rx="16" fill="url(#proofNodeGlow)" stroke="#22d3ee" stroke-width="1.5" />
        <circle cx="34" cy="34" r="14" fill="#00d992" opacity="0.22" filter="url(#softGlow)" />
        <text x="24" y="39" fill="#00d992" font-size="13" font-family="JetBrains Mono, monospace" font-weight="800">01</text>
        <text x="24" y="86" fill="#f7f8f8" font-size="24" font-family="Inter, sans-serif" font-weight="800">Claim</text>
        <text x="24" y="116" fill="#b8b3b0" font-size="13" font-family="Inter, sans-serif">Public copy</text>
        <text x="24" y="152" fill="#d0d6e0" font-size="12" font-family="JetBrains Mono, monospace">static promise</text>
      </g>

      <g class="proof-svg-node" transform="translate(276 74)">
        <rect width="170" height="212" rx="16" fill="#0f172a" />
        <rect width="170" height="212" rx="16" fill="rgba(6,78,59,0.42)" stroke="#34d399" stroke-width="1.5" />
        <circle cx="34" cy="34" r="14" fill="#00d992" opacity="0.22" filter="url(#softGlow)" />
        <text x="24" y="39" fill="#00d992" font-size="13" font-family="JetBrains Mono, monospace" font-weight="800">02</text>
        <text x="24" y="86" fill="#f7f8f8" font-size="24" font-family="Inter, sans-serif" font-weight="800">Contract</text>
        <text x="24" y="116" fill="#b8b3b0" font-size="13" font-family="Inter, sans-serif">Allowed claims</text>
        <text x="24" y="152" fill="#d0d6e0" font-size="12" font-family="JetBrains Mono, monospace">approval gates</text>
      </g>

      <g class="proof-svg-node" transform="translate(496 74)">
        <rect width="170" height="212" rx="16" fill="#0f172a" />
        <rect width="170" height="212" rx="16" fill="rgba(76,29,149,0.42)" stroke="#a78bfa" stroke-width="1.5" />
        <circle cx="34" cy="34" r="14" fill="#7170ff" opacity="0.28" filter="url(#softGlow)" />
        <text x="24" y="39" fill="#c4b5fd" font-size="13" font-family="JetBrains Mono, monospace" font-weight="800">03</text>
        <text x="24" y="86" fill="#f7f8f8" font-size="24" font-family="Inter, sans-serif" font-weight="800">QA</text>
        <text x="24" y="116" fill="#b8b3b0" font-size="13" font-family="Inter, sans-serif">Local checks</text>
        <text x="24" y="152" fill="#d0d6e0" font-size="12" font-family="JetBrains Mono, monospace">qa:full</text>
      </g>

      <g class="proof-svg-node" transform="translate(716 74)">
        <rect width="170" height="212" rx="16" fill="#0f172a" />
        <rect width="170" height="212" rx="16" fill="rgba(120,53,15,0.32)" stroke="#fbbf24" stroke-width="1.5" />
        <circle cx="34" cy="34" r="14" fill="#fbbf24" opacity="0.22" filter="url(#softGlow)" />
        <text x="24" y="39" fill="#fbbf24" font-size="13" font-family="JetBrains Mono, monospace" font-weight="800">04</text>
        <text x="24" y="86" fill="#f7f8f8" font-size="24" font-family="Inter, sans-serif" font-weight="800">Deploy</text>
        <text x="24" y="116" fill="#b8b3b0" font-size="13" font-family="Inter, sans-serif">Pages workflow</text>
        <text x="24" y="152" fill="#d0d6e0" font-size="12" font-family="JetBrains Mono, monospace">deploy run</text>
      </g>

      <g class="proof-svg-node" transform="translate(936 74)">
        <rect width="170" height="212" rx="16" fill="#0f172a" />
        <rect width="170" height="212" rx="16" fill="rgba(136,19,55,0.3)" stroke="#fb7185" stroke-width="1.5" />
        <circle cx="34" cy="34" r="14" fill="#fb7185" opacity="0.24" filter="url(#softGlow)" />
        <text x="24" y="39" fill="#fb7185" font-size="13" font-family="JetBrains Mono, monospace" font-weight="800">05</text>
        <text x="24" y="86" fill="#f7f8f8" font-size="24" font-family="Inter, sans-serif" font-weight="800">Live</text>
        <text x="24" y="116" fill="#b8b3b0" font-size="13" font-family="Inter, sans-serif">Fetched URL</text>
        <text x="24" y="152" fill="#d0d6e0" font-size="12" font-family="JetBrains Mono, monospace">expected text</text>
      </g>

      <g transform="translate(56 304)">
        <rect width="1050" height="22" rx="11" fill="rgba(0,217,146,0.08)" stroke="rgba(0,217,146,0.22)" />
        <text x="18" y="15" fill="#b8b3b0" font-size="10" font-family="JetBrains Mono, monospace">static safety rail: no analytics · no forms · no backend · no fake proof · no private data</text>
      </g>
    </svg>
  </div>

  <div class="proof-chain-node-grid">
    {nodes.map((node) => (
      <article class="proof-chain-node" data-proof-chain-node={node.id}>
        <span>{node.number} · {node.title}</span>
        <h3>{node.subtitle}</h3>
        <p>{node.body}</p>
      </article>
    ))}
  </div>
</section>
